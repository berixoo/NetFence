<UserControl x:Class="NetFence.App.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource ContentBackground}">
        <StackPanel Margin="24" MaxWidth="520">

            <!-- ===== Appearance Section ===== -->
            <TextBlock Text="&#x25A0;" FontSize="12" Margin="0,0,0,8"
                       Foreground="{DynamicResource AccentBlue}"/>
            <TextBlock x:Name="AppearanceSectionLabel" FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,12" Foreground="{DynamicResource PrimaryText}"/>

            <!-- Language -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="LanguageLabel" FontSize="13"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="LanguageDesc" FontSize="11"
                                   Foreground="{DynamicResource MutedText}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="LanguageBox" Grid.Column="1" Width="160"
                              SelectionChanged="LanguageBox_SelectionChanged"
                              Height="32" VerticalAlignment="Center">
                        <ComboBoxItem x:Name="LangEnItem" Tag="en-US"/>
                        <ComboBoxItem x:Name="LangZhItem" Tag="zh-CN"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Theme -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="ThemeLabel" FontSize="13"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="ThemeDesc" FontSize="11"
                                   Foreground="{DynamicResource MutedText}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="ThemeBox" Grid.Column="1" Width="160"
                              SelectionChanged="ThemeBox_SelectionChanged"
                              Height="32" VerticalAlignment="Center">
                        <ComboBoxItem x:Name="ThemeSystemItem" Tag="system"/>
                        <ComboBoxItem x:Name="ThemeDarkItem" Tag="dark"/>
                        <ComboBoxItem x:Name="ThemeLightItem" Tag="light"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- ===== Guardian Section ===== -->
            <TextBlock x:Name="GuardianSectionLabel" FontSize="15" FontWeight="SemiBold"
                       Margin="0,16,0,12" Foreground="{DynamicResource PrimaryText}"/>

            <!-- Enable Process Watcher -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="GuardianLabel" FontSize="13"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="GuardianDesc" FontSize="11"
                                   Foreground="{DynamicResource MutedText}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <CheckBox x:Name="GuardianToggle" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="GuardianToggle_Changed"
                              Unchecked="GuardianToggle_Changed"/>
                </Grid>
            </Border>

            <!-- Auto-start -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="AutoStartLabel" FontSize="13"
                                   Foreground="{DynamicResource PrimaryText}"/>
                        <TextBlock x:Name="AutoStartDesc" FontSize="11"
                                   Foreground="{DynamicResource MutedText}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <CheckBox x:Name="AutoStartToggle" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="AutoStartToggle_Changed"
                              Unchecked="AutoStartToggle_Changed"/>
                </Grid>
            </Border>

            <!-- ===== System Section ===== -->
            <TextBlock x:Name="SystemSectionLabel" FontSize="15" FontWeight="SemiBold"
                       Margin="0,16,0,12" Foreground="{DynamicResource PrimaryText}"/>

            <!-- Open Log + Uninstall -->
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,12" Margin="0,0,0,8">
                <StackPanel>
                    <Button x:Name="OpenLogButton" Height="32" HorizontalAlignment="Left"
                            MinWidth="140" Click="OpenLogButton_Click"
                            Background="{DynamicResource ButtonSecondaryBackground}"
                            Foreground="{DynamicResource ButtonSecondaryForeground}"
                            BorderBrush="{DynamicResource ButtonSecondaryBorder}"/>
                    <Button x:Name="UninstallButton" Height="32" HorizontalAlignment="Left"
                            MinWidth="140" Margin="0,10,0,0"
                            Click="UninstallButton_Click"
                            Background="{DynamicResource ButtonDangerBackground}"
                            Foreground="{DynamicResource ButtonDangerForeground}"
                            BorderThickness="0"/>
                </StackPanel>
            </Border>

            <!-- ===== About Section ===== -->
            <TextBlock x:Name="AboutSectionLabel" FontSize="15" FontWeight="SemiBold"
                       Margin="0,16,0,12" Foreground="{DynamicResource PrimaryText}"/>

            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8"
                    Padding="16,14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="NetFence" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBlue}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="AboutVersion" FontSize="11"
                               Foreground="{DynamicResource MutedText}" Margin="0,0,0,8"/>
                    <TextBlock x:Name="AboutText" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
