<Window x:Class="NetFence.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetFence" Height="680" Width="1080" MinHeight="560" MinWidth="920"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="NetFence" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock x:Name="LanguageLabel" Grid.Column="1" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <ComboBox x:Name="LanguageBox" Grid.Column="2" Width="140" Height="30" SelectionChanged="LanguageBox_SelectionChanged"/>
        </Grid>

        <TextBlock x:Name="AdminText" Grid.Row="1" Margin="0,0,0,12" Foreground="DarkGreen"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="96"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TargetPathLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="PathBox" Grid.Row="0" Grid.Column="1" Height="30" VerticalContentAlignment="Center" Margin="0,4,8,4"/>
            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="SelectExeButton" MinWidth="104" Height="32" Padding="12,0" Margin="4" Click="SelectExeButton_Click"/>
                <Button x:Name="SelectFolderButton" MinWidth="116" Height="32" Padding="12,0" Margin="4" Click="SelectFolderButton_Click"/>
            </StackPanel>

            <TextBlock x:Name="RuleNameLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,6,10,6"/>
            <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Height="30" VerticalContentAlignment="Center" Margin="0,4,8,4"/>

            <CheckBox x:Name="IncludeLinkedCheck" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,8,0,8" IsChecked="True"/>
        </Grid>

        <WrapPanel Grid.Row="3" Margin="0,8,0,10">
            <Button x:Name="ScanButton" MinWidth="124" Height="32" Padding="12,0" Margin="4" Click="ScanButton_Click"/>
            <Button x:Name="BlockButton" MinWidth="124" Height="32" Padding="12,0" Margin="4" Click="BlockButton_Click"/>
            <Button x:Name="UnblockButton" MinWidth="112" Height="32" Padding="12,0" Margin="4" Click="UnblockButton_Click"/>
            <Button x:Name="UnblockSelectedButton" MinWidth="128" Height="32" Padding="12,0" Margin="4" Click="UnblockSelectedButton_Click"/>
            <Button x:Name="UnblockAllButton" MinWidth="118" Height="32" Padding="12,0" Margin="4" Click="UnblockAllButton_Click"/>
            <Button x:Name="ExportButton" MinWidth="132" Height="32" Padding="12,0" Margin="4" Click="ExportButton_Click"/>
            <Button x:Name="OpenLogButton" MinWidth="112" Height="32" Padding="12,0" Margin="4" Click="OpenLogButton_Click"/>
            <Button x:Name="RefreshButton" MinWidth="104" Height="32" Padding="12,0" Margin="4" Click="RefreshButton_Click"/>
        </WrapPanel>

        <TabControl x:Name="Tabs" Grid.Row="4" Margin="0,0,0,10">
            <TabItem x:Name="CandidatesTab">
                <DataGrid x:Name="CandidatesGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn x:Name="CandidateBlockColumn" Binding="{Binding Selected}" Width="70"/>
                        <DataGridTextColumn x:Name="CandidateReasonColumn" Binding="{Binding Reason}" IsReadOnly="True" Width="230"/>
                        <DataGridTextColumn x:Name="CandidatePidColumn" Binding="{Binding ProcessId}" IsReadOnly="True" Width="70"/>
                        <DataGridTextColumn x:Name="CandidateProcessColumn" Binding="{Binding ProcessName}" IsReadOnly="True" Width="130"/>
                        <DataGridTextColumn x:Name="CandidateProgramColumn" Binding="{Binding Program}" IsReadOnly="True" Width="520"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem x:Name="RulesTab">
                <DataGrid x:Name="RulesGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Extended" SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="RuleProfileColumn" Binding="{Binding ProfileName}" Width="150"/>
                        <DataGridTextColumn x:Name="RuleDirectionColumn" Binding="{Binding Direction}" Width="90"/>
                        <DataGridTextColumn x:Name="RuleEnabledColumn" Binding="{Binding Enabled}" Width="80"/>
                        <DataGridTextColumn x:Name="RuleActionColumn" Binding="{Binding Action}" Width="80"/>
                        <DataGridTextColumn x:Name="RuleProgramColumn" Binding="{Binding Program}" Width="620"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="5">
            <ProgressBar x:Name="Progress" Height="4" Margin="0,0,0,6" IsIndeterminate="True" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusText" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
